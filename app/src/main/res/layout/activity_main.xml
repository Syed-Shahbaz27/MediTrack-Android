<?xml version="1.0" encoding="utf-8"?>
    <!--
        MainActivity Layout — the Home Dashboard.
        DrawerLayout is the ROOT element because it manages the slide-out drawer.
        Everything the user normally sees sits in the first child (LinearLayout).
        The NavigationView is the drawer panel — hidden until the hamburger is tapped.
    -->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Main visible content ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- Teal Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/teal_primary"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/btnHamburger"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="☰"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MediTrack ❤"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <TextView
                android:id="@+id/btnProfile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="👤"
                android:textSize="20sp"
                android:gravity="center"
                android:background="@color/white"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Scrollable Dashboard Body -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Hello [Name] -->
                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello User 👋"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_grey"
                    android:layout_marginBottom="2dp"/>

                <!-- Last login -->
                <TextView
                    android:id="@+id/tvLastLogin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last login: —"
                    android:textSize="11sp"
                    android:textColor="@color/medium_grey"
                    android:layout_marginBottom="16dp"/>

                <!-- Medication Reminder Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMedReminder"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    app:cardBackgroundColor="@color/soft_green"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvMedReminder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:text="💊  No medications yet"
                        android:textSize="16sp"
                        android:textColor="@color/dark_grey"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- Appointment Reminder Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardAptReminder"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    app:cardBackgroundColor="@color/soft_green"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/tvAptReminder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="18dp"
                        android:text="📅  No appointments yet"
                        android:textSize="16sp"
                        android:textColor="@color/dark_grey"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- 2x2 Feature Grid — teal background matching prototype -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/teal_primary"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:id="@+id/cardMedication"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/teal_primary"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginEnd="4dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💊" android:textSize="36sp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Medication"
                                android:textColor="@color/soft_green"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cardAppointments"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/teal_primary"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginStart="4dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅" android:textSize="36sp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Appointments"
                                android:textColor="@color/soft_green"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/cardPharmacy"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/teal_primary"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginEnd="4dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📍" android:textSize="36sp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pharmacy"
                                android:textColor="@color/soft_green"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/cardEmergency"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@color/teal_primary"
                            android:clickable="true"
                            android:focusable="true"
                            android:layout_marginStart="4dp">
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠️" android:textSize="36sp"/>
                            <TextView android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Emergency"
                                android:textColor="@color/soft_green"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Bottom Navigation Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/teal_primary"
            android:orientation="horizontal">

            <LinearLayout android:id="@+id/btnNavHome"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏠" android:textSize="18sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Home" android:textColor="@color/white" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnNavMeds"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💊" android:textSize="18sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Meds" android:textColor="@color/white" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnNavAppointments"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📅" android:textSize="18sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Appointments" android:textColor="@color/white" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/btnNavProfile"
                android:layout_width="0dp" android:layout_height="match_parent"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:clickable="true" android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👤" android:textSize="18sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Profile" android:textColor="@color/white" android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Navigation Drawer Panel (slides from left) ───────────── -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/nav_drawer_menu"
        app:itemTextColor="@color/dark_grey"
        app:itemIconTint="@color/teal_primary"/>

</androidx.drawerlayout.widget.DrawerLayout>
