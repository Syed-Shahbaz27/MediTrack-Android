<?xml version="1.0" encoding="utf-8"?>
<!--
    PharmacyLocatorActivity — GPS Sub-Activity matching prototype Screen 9.
    GPS location is requested at runtime and shown in tvGpsStatus.
    The 3 pharmacies are hardcoded because Google Maps SDK requires
    billing setup (credit card) which is not practical for a student project.
    The GPS coordinate is still REAL — we get the device's actual location.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ── Teal Toolbar ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/teal_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MediTrack ❤"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View android:layout_width="40dp" android:layout_height="40dp"/>
    </LinearLayout>

    <!-- ── Title Row ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nearby Pharmacies"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/teal_primary"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏪"
            android:textSize="28sp"/>
    </LinearLayout>

    <!-- GPS Status — populated by Java after permission granted -->
    <TextView
        android:id="@+id/tvGpsStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍 Locating you..."
        android:textSize="13sp"
        android:textColor="@color/medium_grey"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="12dp"/>

    <!-- Map placeholder — large emoji matching prototype aesthetic -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:text="🗺️"
        android:textSize="80sp"
        android:gravity="center"
        android:background="@color/card_green"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- ── Pharmacy Cards ────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp">

        <!-- Muscat Pharmacy -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍" android:textSize="20sp"/>

                <TextView android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Muscat Pharmacy"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_grey"
                    android:layout_marginStart="10dp"/>

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.8 km"
                    android:textSize="14sp"
                    android:textColor="@color/teal_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ibn Sina Pharmacy -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍" android:textSize="20sp"/>

                <TextView android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ibn Sina Pharmacy"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_grey"
                    android:layout_marginStart="10dp"/>

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.6 km"
                    android:textSize="14sp"
                    android:textColor="@color/teal_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Avicen Pharmacy -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍" android:textSize="20sp"/>

                <TextView android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Avicen Pharmacy"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/dark_grey"
                    android:layout_marginStart="10dp"/>

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.0 km"
                    android:textSize="14sp"
                    android:textColor="@color/teal_primary"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Footer GPS note matching prototype -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Using your Current GPS location"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/dark_grey"
        android:gravity="center"
        android:padding="16dp"/>

</LinearLayout>