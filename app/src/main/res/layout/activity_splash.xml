<?xml version="1.0" encoding="utf-8"?>
    <!--
        SplashActivity Layout — the Welcome/Landing screen.
        This is the first thing users see. Matches prototype Screen 1 exactly.
        Session check happens in Java — if already logged in, this never shows.
    -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- ── Teal Header Bar ─────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/teal_primary"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="💊"
            android:textSize="24sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_heart"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="📋"
            android:textSize="24sp"
            android:gravity="center"/>
    </LinearLayout>

    <!-- ── Scrollable Content ──────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="40dp"
            android:paddingBottom="28dp"
            android:gravity="center_horizontal">

            <!-- Welcome Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to\nMediTrack"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/dark_grey"
                android:gravity="center"
                android:lineSpacingMultiplier="1.1"/>

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_tagline"
                android:textSize="16sp"
                android:textColor="@color/medium_grey"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="36dp"/>

            <!-- Medication Images (emoji stand-ins matching prototype) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="48dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💊"
                    android:textSize="72sp"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="💉"
                    android:textSize="72sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- LOG IN Button — filled teal, matches prototype -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToLogin"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_login"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="@color/teal_primary"
                app:cornerRadius="30dp"
                android:layout_marginBottom="16dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <!-- REGISTER Button — outline style, matches prototype -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoToRegister"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/btn_register"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/teal_primary"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/teal_primary"
                app:strokeWidth="2dp"
                app:cornerRadius="30dp"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
