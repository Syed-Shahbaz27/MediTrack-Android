<?xml version="1.0" encoding="utf-8"?>
    <!--
        Border style for Spinner dropdowns.
        Spinners don't support TextInputLayout styling so we give them
        a custom shape background to match the green-bordered input fields.
    -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/white"/>
    <stroke android:width="1.5dp" android:color="@color/soft_green"/>
    <corners android:radius="12dp"/>
    <padding android:left="12dp" android:top="4dp"
        android:right="12dp" android:bottom="4dp"/>
</shape>
